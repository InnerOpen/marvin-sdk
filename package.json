{
  "name": "@inneropen/marvin-sdk",
  "version": "2.0.0-next.20",
  "description": "Official TypeScript SDK for Marvin CMS",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./publish": {
      "types": "./dist/publish.d.ts",
      "import": "./dist/publish.js",
      "require": "./dist/publish.cjs"
    },
    "./platform": {
      "types": "./dist/platform.d.ts",
      "import": "./dist/platform.js",
      "require": "./dist/platform.cjs"
    },
    "./core": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js",
      "require": "./dist/types/index.cjs"
    }
  },
  "files": [
    "dist/**/*",
    "README.md",
    "examples.md",
    "QUICKSTART.md"
  ],
  "keywords": [
    "marvin",
    "cms",
    "sdk",
    "typescript",
    "headless-cms",
    "publishing",
    "workspace",
    "astro",
    "nextjs",
    "nuxt"
  ],
  "author": {
    "name": "Marvin Project",
    "email": "contact@inneropen.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/inneropen/marvin-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/inneropen/marvin-sdk/issues"
  },
  "homepage": "https://github.com/inneropen/marvin-sdk#readme",
  "scripts": {
    "build": "tsup src/index.ts src/publish.ts src/platform.ts src/types/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts src/publish.ts src/platform.ts src/types/index.ts --format esm,cjs --dts --watch",
    "generate:types": "openapi-typescript http://localhost:8080/openapi.json -o src/generated/schema.ts",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "docs:serve": "mkdocs serve",
    "docs:build": "mkdocs build",
    "docs:deploy": "mkdocs gh-deploy"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^26.1.0",
    "openapi-typescript": "^7.13.0",
    "semantic-release": "^25.0.5",
    "tsup": "^8.5.1"
  },
  "dependencies": {
    "mkdocs": "^0.0.1"
  }
}
